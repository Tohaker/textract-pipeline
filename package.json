{
	"name": "textract-pipeline",
	"version": "1.0.0",
	"description": "Pipeline infrastructure and application for the AWS Textract service",
	"type": "module",
	"scripts": {
		"deploy": "cdk deploy --all --require-approval never",
		"check:types": "tsc",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"test": "vitest"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Tohaker/textract-pipeline.git"
	},
	"author": "Miles Bardon",
	"license": "UNLICENSED",
	"bugs": {
		"url": "https://github.com/Tohaker/textract-pipeline/issues"
	},
	"homepage": "https://github.com/Tohaker/textract-pipeline#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@tsconfig/node24": "24.0.4",
		"@types/aws-lambda": "8.10.161",
		"@types/node": "25.6.0",
		"aws-cdk": "2.1120.0",
		"aws-sdk-client-mock": "4.1.0",
		"aws-sdk-client-mock-jest": "4.1.0",
		"chalk": "5.6.2",
		"typescript": "6.0.3",
		"vitest": "4.1.5"
	},
	"dependencies": {
		"@aws-lambda-powertools/batch": "2.33.0",
		"@aws-lambda-powertools/jmespath": "2.33.0",
		"@aws-lambda-powertools/logger": "2.33.0",
		"@aws-sdk/client-s3": "3.1040.0",
		"@aws-sdk/client-textract": "3.1040.0",
		"amazon-textract-response-parser": "0.4.3",
		"aws-cdk-lib": "2.252.0",
		"aws-lambda": "1.0.7",
		"constructs": "10.6.0"
	}
}
